<Window x:Class="Kanban.Desktop.CardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка" Height="500" Width="400">
    <StackPanel Margin="10">
        <TextBox x:Name="TitleBox" Margin="0,0,0,5"/>
        <TextBox x:Name="DescriptionBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,5"/>
        <DatePicker x:Name="DeadlinePicker" Margin="0,0,0,5"/>
        <TextBox x:Name="AssigneeBox" Margin="0,0,0,5"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Сохранить" Click="Save_Click" Margin="0,0,5,0"/>
            <Button Content="Удалить" Click="Delete_Click"/>
        </StackPanel>
        <TextBlock Text="Комментарии" FontWeight="Bold"/>
        <ScrollViewer Height="150">
            <StackPanel x:Name="CommentsPanel"/>
        </ScrollViewer>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <TextBox x:Name="NewCommentBox" Width="250" Margin="0,0,5,0"/>
            <Button Content="Добавить" Click="AddComment_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
