<Window x:Class="Kanban.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="220" Width="300">
    <StackPanel Margin="20">
        <TextBox x:Name="UsernameBox" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,5"/>
        <StackPanel Orientation="Horizontal">
            <Button Content="Войти" Click="Login_Click" Margin="0,0,5,0"/>
            <Button Content="Регистрация" Click="Register_Click"/>
        </StackPanel>
        <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
