<Window x:Class="Kanban.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kanban" Height="700" Width="1200">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <ComboBox x:Name="BoardsCombo" Width="200" SelectionChanged="BoardsCombo_SelectionChanged"/>
            <TextBox x:Name="NewBoardTitle" Width="150" Margin="10,0,0,0"/>
            <Button Content="Новая доска" Click="NewBoard_Click" Margin="5,0,0,0"/>
        </StackPanel>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ColumnsPanel" Orientation="Horizontal" Margin="10"/>
        </ScrollViewer>
    </DockPanel>
</Window>
